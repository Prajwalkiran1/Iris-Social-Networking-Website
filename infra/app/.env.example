# Optional env for the local app stack (infra/app/docker-compose.yml).
# Copy to `infra/app/.env` and fill in for working Firebase auth. The pipeline
# and the /api/health gate work WITHOUT these — only login needs real values.
FIREBASE_PROJECT_ID=iris-social-3c4bd

# Public Firebase web identifiers (from the Firebase console > Project settings).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=iris-social-3c4bd
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
