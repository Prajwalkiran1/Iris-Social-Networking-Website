# Copy to backend/.env and fill in. Never commit the real .env.

# --- Neo4j ---
# Local Docker:  bolt://localhost:7687
# Neo4j Aura:    neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Community Edition only supports "neo4j". Aura free = "neo4j" too.
NEO4J_DATABASE=neo4j

# --- Firebase token verification ---
# The app only VERIFIES ID tokens, which needs just the project id (no
# private key / no secret). Find it in the Firebase web config.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: full service-account JSON (one line) — only if you later add
# privileged Admin operations. Not required for auth.
# FIREBASE_SERVICE_ACCOUNT=

# --- Server / CORS ---
PORT=5001
# Deployed frontend origin (e.g. https://iris.vercel.app). Optional in dev.
FRONTEND_ORIGIN=
