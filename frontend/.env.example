# Copy to frontend/.env.local and fill with YOUR Firebase project's values.
# Firebase console -> Project settings (gear) -> General tab ->
#   "Your apps" -> Web app -> SDK setup and configuration -> "Config".
# These are web client identifiers, not secrets, but keep them out of git
# so the repo isn't tied to any one person's project.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend API base URL. Leave unset in dev (Vite proxies /api → :5001).
# In production set to the deployed backend, e.g. https://iris-api.onrender.com/api
VITE_API_BASE_URL=
